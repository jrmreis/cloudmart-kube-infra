apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: cloudmart-ingress
  annotations:
    kubernetes.io/ingress.class: "nginx"
    nginx.ingress.kubernetes.io/ssl-redirect: "true"
    cert-manager.io/cluster-issuer: "letsencrypt-prod"
spec:
  tls:
  - hosts:
    - {{ app_domain }}
    secretName: cloudmart-tls
  rules:
  - host: {{ app_domain }}
    http:
      paths:
      - path: /api
        pathType: Prefix
        backend:
          service:
            name: cloudmart-backend
            port:
              number: 5000
      - path: /
        pathType: Prefix
        backend:
          service:
            name: cloudmart-frontend
            port:
              number: 5001
